code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec2 RedDisplacement = vec2(1.000000, 0.000000);
uniform sampler2D ScreenTexture : filter_linear_mipmap, hint_screen_texture;
uniform vec2 GreenDisplacement = vec2(1.000000, -1.000000);
uniform vec2 BlueDisplacement = vec2(-1.000000, 0.000000);



void fragment() {
// Input:12
	vec2 n_out12p0 = SCREEN_UV;


// Input:16
	vec2 n_out16p0 = SCREEN_PIXEL_SIZE;


// Vector2Parameter:2
	vec2 n_out2p0 = RedDisplacement;


// VectorOp:17
	vec2 n_out17p0 = n_out16p0 * n_out2p0;


// VectorOp:13
	vec2 n_out13p0 = n_out12p0 + n_out17p0;


// FloatConstant:20
	float n_out20p0 = 0.000000;


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = textureLod(ScreenTexture, n_out13p0, n_out20p0);


// Vector2Parameter:4
	vec2 n_out4p0 = GreenDisplacement;


// VectorOp:18
	vec2 n_out18p0 = n_out16p0 * n_out4p0;


// VectorOp:14
	vec2 n_out14p0 = n_out12p0 + n_out18p0;


	vec4 n_out9p0;
// Texture2D:9
	n_out9p0 = textureLod(ScreenTexture, n_out14p0, n_out20p0);


// Vector2Parameter:3
	vec2 n_out3p0 = BlueDisplacement;


// VectorOp:19
	vec2 n_out19p0 = n_out16p0 * n_out3p0;


// VectorOp:15
	vec2 n_out15p0 = n_out12p0 + n_out19p0;


	vec4 n_out10p0;
// Texture2D:10
	n_out10p0 = textureLod(ScreenTexture, n_out15p0, n_out20p0);


// VectorCompose:11
	vec3 n_out11p0 = vec3(n_out8p0.x, n_out9p0.x, n_out10p0.x);


// Output:0
	COLOR.rgb = n_out11p0;


}
